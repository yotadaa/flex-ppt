llm_api_key=sk-secret-key
llm_endpoint=http://localhost:20128/v1
llm_model=openai-compatible-model

# Current local-first database mode.
FLEX_DATABASE_MODE=local-mysql
LOCAL_DATABASE_URL="mysql://root:password@127.0.0.1:3306/flex_ppt"

# Future Supabase/Postgres mode:
# FLEX_DATABASE_MODE=supabase
DATABASE_URL="postgresql://example_1,postgresql://example_2,postgresql://example_3"
DIRECT_URL="postgresql://example_1,postgresql://example_2,postgresql://example_3"

# Optional for future Supabase Auth mode. Current app auth is local-first.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
